{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "zainly-alpha.vercel.app" }],
      "destination": "https://zainly.app/$1",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/send-notifications",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/send-reminder",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/send-evening",
      "schedule": "0 18 * * *"
    }
  ]
}
